# --- Quarto & Web Output ---
/.quarto/
/_site/
/_output/
/site_libs/
*_files/
# Ignore all rendered HTML and PDF at the root and in subfolders
# (This keeps your Obsidian vault from being cluttered with non-markdown files)
*.html
*.pdf
*.docx
*.tex

# --- R & Python ---
.Rproj.user
.Rhistory
.RData
.Ruserdata
**/*.quarto_ipynb
.virtualenv
venv/

# --- LaTeX Intermediates ---
*.aux
*.fdb_latexmk
*.fls
*.log
*.toc
*.out
*.synctex.gz
*.blg
*.bbl

# --- OS Generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# --- Project Specific Patterns ---
# Ignore the fragment renders generated by your 'include' statements
sections/*.html
sections/*_files/
abstract/*.html
abstract/*_files/
notes/*.html
notes/*_files/

# --- Other ---
.gdsheet
.hugo_build.lock
.luarc.json
_extensions/
_freeze/